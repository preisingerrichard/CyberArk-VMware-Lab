# ── CyberArk installer files ────────────────────────────────────
# Exclude all files inside Installers/ but keep the folder structure
# visible on GitHub via .gitkeep placeholders
Installers/**/*
!Installers/**/.gitkeep

# ── Windows Server ISO ───────────────────────────────────────────
ISO/

# ── Claude Code project files ────────────────────────────────────
.claude/

# ── Runtime state (generated during deployment) ──────────────────
Config/DeployedVMs.xml

# ── SSH keys (generated per-VM, machine-specific) ────────────────
Config/pta_lab_key
Config/pta_lab_key.pub
Config/psmp_lab_key
Config/psmp_lab_key.pub

# ── Windows null device (ssh.exe UserKnownHostsFile=NUL artifact) ─
NUL

# ── Deployment logs ──────────────────────────────────────────────
Logs/

# ── Temp files ───────────────────────────────────────────────────
*.tmp
